{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    /* bash no cmd: npx tsc --version 
    
    Dependendo da versão, vc coloca o número, mas lembra que tem que mudar em
    E:\.Lucas Novais\Programa-o-para-WEB-2---Completo\react_academico\tsconfig.app.json

    */
    "ignoreDeprecations": "5.0",

    "baseUrl": "./",
    
    "paths": {
      "@/*": ["src/*"]
    },

    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "isolatedModules": true,
    "declaration": false
  },
  "exclude": ["node_modules", "dist", "**/*.spec.ts"]
}